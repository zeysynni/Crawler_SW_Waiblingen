# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored and must never be committed.

# No LLM key needed — the crawler is fully deterministic (crawl4ai).

# Optional — phone alerts + end-of-run report (no-op if absent)
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Optional — only needed for `--upload` (knowledge-base API)
AIGATEWAY_KEY=
# Optional overrides for the upload target:
# AIGATEWAY_KB_ID=
# AIGATEWAY_IMPORT_STRATEGY_ID=
# UPLOAD_STATE_FILE=upload_state.json
